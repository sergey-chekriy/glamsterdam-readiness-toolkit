{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "types": ["node"],
    "skipLibCheck": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "@grt/core": ["packages/core/src/index.ts"],
      "@grt/rules": ["packages/rules/src/index.ts"],
      "@grt/fixtures": ["packages/fixtures/src/index.ts"]
    }
  }
}